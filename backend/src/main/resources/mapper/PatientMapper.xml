<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hospital.accompany.mapper.PatientMapper">

    <select id="selectPatientPage" resultType="com.hospital.accompany.entity.Patient">
        SELECT * FROM patient
        WHERE deleted = 0 AND status = 1
        <if test="wardId != null">
            AND ward_id = #{wardId}
        </if>
        <if test="patientName != null and patientName != ''">
            AND patient_name LIKE CONCAT('%', #{patientName}, '%')
        </if>
        <if test="patientNo != null and patientNo != ''">
            AND patient_no LIKE CONCAT('%', #{patientNo}, '%')
        </if>
        ORDER BY create_time DESC
    </select>

</mapper>
